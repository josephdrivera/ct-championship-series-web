# Convex
# Dev: from `npx convex dev`. Production: from `npx convex deploy` output (Vercel must use prod URL).
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# Clerk webhook (set in Convex dashboard → Production → Environment Variables, not in Vercel):
# CLERK_WEBHOOK_SECRET=whsec_...
# Clerk → Webhooks → URL: https://<deployment>.convex.site/clerk-webhook
# Example production site hostname: giddy-rhinoceros-119.convex.site

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Optional: duplicate of publishable key for server-only reads (Vercel Production) if needed
# CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Site URL (used for sitemap.xml and robots.txt)
NEXT_PUBLIC_SITE_URL=

# VAPID (Push Notifications)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Resend (transactional email — invites + optional announcement/reminder/welcome; see templates/emails/)
RESEND_API_KEY=
# Verified domain in Resend, e.g. CT Championship Series <noreply@yourdomain.com>
EMAIL_FROM=CT Championship Series <noreply@ctchampionshipseries.com>
# Optional display name in templates (defaults to CT Championship Series)
# EMAIL_APP_NAME=CT Championship Series

# ── Convex Dashboard Environment Variables ──
# These are NOT set here — set them in the Convex production dashboard.
# CLERK_JWT_ISSUER_DOMAIN=         (required for Convex auth)
# CLERK_SECRET_KEY=                (optional: commissioner check-in emails if user.email missing in Convex)
# RESEND_API_KEY=                  (optional: commissioner check-in notification emails from Convex actions)
# EMAIL_FROM=                      (same as Vercel — Resend from-address for Convex-sent mail)
# EMAIL_APP_NAME=                  (optional, matches above)
# VAPID_PUBLIC_KEY=                 (optional, push notifications)
# VAPID_PRIVATE_KEY=                (optional, push notifications)
# VAPID_SUBJECT=mailto:you@example  (optional, push notifications)
